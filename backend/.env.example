PORT=5000
NODE_ENV=production

# Comma-separated list for CORS allowlist. Include your Vercel domain(s).
FRONTEND_URL=https://your-frontend.vercel.app,https://your-custom-domain.com

# Used in backend-generated email CTA links.
FRONTEND_PUBLIC_URL=https://your-frontend.vercel.app

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

HUGGINGFACE_API_KEY=your_huggingface_api_key
HUGGINGFACE_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo
HF_API_URL=https://router.huggingface.co/together/v1/chat/completions

EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password
